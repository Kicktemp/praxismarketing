---
import BaseLayout from '../layouts/BaseLayout.astro';
import SiteNav from '../components/SiteNav.astro';
import SiteFooter from '../components/SiteFooter.astro';
import CookieConsent from '../components/CookieConsent.astro';
---

<BaseLayout
  title="Impressum"
  description="Impressum der Kicktemp GmbH"
  robots="noindex, nofollow"
>
  <SiteNav />

  <div class="max-w-2xl mx-auto px-6 py-16">
    <h1 class="text-3xl font-black text-dark mb-10">Impressum</h1>

    <div class="prose prose-sm max-w-none text-gray-700 leading-relaxed space-y-8">

      <section>
        <h2 class="text-dark font-bold text-lg mb-2">Angaben gemäß § 5 TMG</h2>
        <p>
          Kicktemp GmbH<br />
          Jungfernstieg 7<br />
          20354 Hamburg<br />
          Deutschland
        </p>
      </section>

      <section>
        <h2 class="text-dark font-bold text-lg mb-2">Vertreten durch</h2>
        <p>
          Niels Nübel (Geschäftsführer)<br />
          Stefan Wendhausen (Geschäftsführer)
        </p>
      </section>

      <section>
        <h2 class="text-dark font-bold text-lg mb-2">Registereintrag</h2>
        <p>
          Eingetragen im Handelsregister.<br />
          Registergericht: Amtsgericht Hamburg<br />
          Registernummer: HRB 195459
        </p>
      </section>

      <section>
        <h2 class="text-dark font-bold text-lg mb-2">Kontakt</h2>
        <p>
          Telefon: +49 40 6094 3030-0<br />
          Telefax: +49 40 6094 3030-1<br />
          E-Mail: <a href="mailto:hello@kicktemp.com" class="text-blue hover:underline">hello@kicktemp.com</a>
        </p>
      </section>

      <section>
        <h2 class="text-dark font-bold text-lg mb-2">Umsatzsteuer-ID</h2>
        <p>
          Umsatzsteuer-Identifikationsnummer gemäß § 27 a Umsatzsteuergesetz:<br />
          DE319350527
        </p>
      </section>

      <section>
        <h2 class="text-dark font-bold text-lg mb-2">Verantwortlich für den Inhalt nach § 55 Abs. 2 RStV</h2>
        <p>
          Niels Nübel<br />
          Jungfernstieg 7<br />
          20354 Hamburg
        </p>
      </section>

      <section>
        <h2 class="text-dark font-bold text-lg mb-2">Verbraucherstreitbeilegung / Universalschlichtungsstelle</h2>
        <p>
          Die Europäische Kommission stellt eine Plattform zur Online-Streitbeilegung (OS) bereit:
          <a href="https://ec.europa.eu/consumers/odr/" target="_blank" rel="noopener noreferrer" class="text-blue hover:underline">
            https://ec.europa.eu/consumers/odr/
          </a>.<br />
          Unsere E-Mail-Adresse finden Sie oben im Impressum.
        </p>
        <p class="mt-3">
          Wir sind nicht bereit oder verpflichtet, an Streitbeilegungsverfahren vor einer
          Verbraucherschlichtungsstelle teilzunehmen.
        </p>
      </section>

    </div>
  </div>

  <SiteFooter />
  <CookieConsent />
</BaseLayout>
