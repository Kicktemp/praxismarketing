---
import BaseLayout from '../layouts/BaseLayout.astro';
import SiteNav from '../components/SiteNav.astro';
import SiteFooter from '../components/SiteFooter.astro';
---

<BaseLayout
  title="Digitaler Partner für Kliniken & Praxen"
  description="Wir übernehmen alles Digitale für ästhetische Kliniken und Praxen – Website, Technik, Werbung und Auswertung. Aus einer Hand."
>
  <script type="application/ld+json" slot="head" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@graph": [
      {
        "@type": "Organization",
        "@id": "https://praxismarketing.kicktemp.com/#organization",
        "name": "Kicktemp GmbH",
        "url": "https://praxismarketing.kicktemp.com",
        "logo": "https://praxismarketing.kicktemp.com/favicon.svg",
        "foundingDate": "2018",
        "address": {
          "@type": "PostalAddress",
          "streetAddress": "Jungfernstieg 7",
          "addressLocality": "Hamburg",
          "postalCode": "20354",
          "addressCountry": "DE"
        },
        "contactPoint": {
          "@type": "ContactPoint",
          "email": "praxismarketing@kicktemp.com",
          "contactType": "sales",
          "availableLanguage": "German"
        },
        "areaServed": {
          "@type": "GeoCircle",
          "geoMidpoint": { "@type": "GeoCoordinates", "latitude": 53.5507, "longitude": 9.9930 },
          "geoRadius": "800000"
        },
        "description": "Kicktemp implementiert das Praxis Performance System für ästhetische Kliniken und Praxen — die datenschutzkonforme Schnittstelle zwischen Google Ads und Praxissoftware (mobi.MED, Claysen).",
        "knowsAbout": ["Google Ads", "Praxismarketing", "ästhetische Chirurgie", "mobi.MED", "Claysen", "Server-Side Tracking"],
        "founder": [
          { "@type": "Person", "name": "Niels Nübel" },
          { "@type": "Person", "name": "Stefan Wendhausen" }
        ]
      },
      {
        "@type": "Service",
        "@id": "https://praxismarketing.kicktemp.com/#service",
        "name": "Kicktemp Praxis Performance System",
        "provider": { "@id": "https://praxismarketing.kicktemp.com/#organization" },
        "serviceType": "Praxismarketing",
        "description": "Datenschutzkonforme Schnittstelle zwischen Google Ads und Praxissoftware (mobi.MED, Claysen). Verbindet digitale Werbung mit echten gebuchten Terminen für messbar mehr Patienten.",
        "areaServed": ["DE", "AT", "CH"],
        "audience": {
          "@type": "Audience",
          "audienceType": "Ästhetische Chirurgen, Plastische Chirurgen, Dermatologen, Zahnärzte"
        },
        "offers": {
          "@type": "Offer",
          "priceCurrency": "EUR",
          "availability": "https://schema.org/InStock",
          "description": "Monatliches Retainer-Modell. Erstes Gespräch kostenlos."
        }
      },
      {
        "@type": "WebSite",
        "@id": "https://praxismarketing.kicktemp.com/#website",
        "url": "https://praxismarketing.kicktemp.com",
        "name": "Kicktemp Praxismarketing",
        "publisher": { "@id": "https://praxismarketing.kicktemp.com/#organization" },
        "inLanguage": "de-DE"
      }
    ]
  })} />

  <SiteNav />

  <!-- ── HERO ──────────────────────────────────── -->
  <section class="relative px-6 py-20 text-center overflow-hidden min-h-[420px] flex flex-col justify-center">
    <!-- Background photo -->
    <div
      class="absolute inset-0 bg-cover bg-top bg-no-repeat"
      style="background-image: url('/team/team-hero.jpg')"
    ></div>
    <!-- Dark overlay -->
    <div class="absolute inset-0" style="background: rgba(0,0,0,0.35)"></div>
    <!-- Content -->
    <div class="relative z-10">
      <span class="inline-block bg-white/15 text-white text-xs font-bold tracking-widest uppercase px-4 py-1.5 rounded-full mb-7 border border-white/25">
        Für Kliniken &amp; Praxen
      </span>
      <h1 class="text-white font-black text-4xl sm:text-5xl leading-tight tracking-tight mb-4">
        Alles Digitale.<br />
        <span class="text-blue">Aus einer Hand.</span>
      </h1>
      <p class="text-white/70 text-base leading-relaxed max-w-md mx-auto mt-5 mb-2">
        Wir implementieren das <strong class="text-white/95 font-semibold">Kicktemp Praxis Performance System</strong> —
        die datenschutzkonforme Schnittstelle zwischen Google Ads und Ihrer Praxissoftware.
      </p>
      <p class="text-white/50 text-xs max-w-xs mx-auto mb-10">
        Kompatibel mit mobi.MED · Claysen · und weiteren Praxis-CRM-Systemen
      </p>
      <div class="flex flex-wrap gap-3 justify-center">
        <a
          href="#leistungen"
          class="inline-flex items-center gap-2 bg-blue text-white font-bold text-sm px-7 py-3.5 rounded-lg hover:bg-blue-dark transition-colors"
        >
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
          Was wir machen
        </a>
        <a
          href="#kontakt"
          class="inline-flex items-center gap-2 bg-white/10 border border-white/20 text-white/90 font-semibold text-sm px-7 py-3.5 rounded-lg hover:bg-white/15 transition-colors"
        >
          Jetzt anfragen
        </a>
      </div>
    </div>
  </section>

  <!-- ── STATS BAR ────────────────────────────── -->
  <div class="bg-dark border-t border-white/8 px-6 py-5">
    <div class="max-w-lg mx-auto flex flex-wrap justify-center gap-x-8 gap-y-3 text-center">
      {[
        { value: 'Ø 64x', label: 'ROAS Google Ads' },
        { value: '€ 22', label: 'Ø Kosten pro Termin' },
        { value: '8+', label: 'Jahre Kicktemp' },
        { value: '100%', label: 'Fokus auf Medizin' },
      ].map((s) => (
        <div>
          <div class="text-white font-black text-xl leading-none">{s.value}</div>
          <div class="text-white/40 text-xs mt-1">{s.label}</div>
        </div>
      ))}
    </div>
  </div>

  <!-- ── THREE PILLARS ─────────────────────────── -->
  <section class="bg-blue px-6 py-10">
    <div class="max-w-lg mx-auto flex flex-col gap-6">
      {[
        {
          num: '1',
          title: 'Ein Ansprechpartner statt vier Dienstleister',
          text: 'Kein Koordinationsaufwand zwischen Webdesigner, Programmierer, Werbeagentur und Analyst mehr.',
        },
        {
          num: '2',
          title: 'Mehr Patienten für Ihre Behandlungen',
          text: 'Wir bringen gezielt die Menschen zu Ihnen, die aktiv nach Ihren Leistungen suchen.',
        },
        {
          num: '3',
          title: 'Klarheit darüber, was wirklich funktioniert',
          text: 'Sie sehen erstmals genau, welche Maßnahme welchen Patienten gebracht hat.',
        },
      ].map((p) => (
        <div class="flex items-start gap-4">
          <div class="flex-shrink-0 w-9 h-9 rounded-full bg-white/20 flex items-center justify-center text-white font-extrabold text-sm">
            {p.num}
          </div>
          <p class="text-white/90 text-sm leading-relaxed">
            <strong class="text-white font-bold block mb-0.5 text-base">{p.title}</strong>
            {p.text}
          </p>
        </div>
      ))}
    </div>
  </section>

  <!-- ── SERVICES ───────────────────────────────── -->
  <section class="px-6 py-16 max-w-2xl mx-auto" id="leistungen">
    <p class="text-blue text-xs font-bold tracking-widest uppercase mb-3">Leistungen</p>
    <h2 class="text-dark font-extrabold text-2xl sm:text-3xl tracking-tight mb-3">
      Das Praxis Performance System
    </h2>
    <p class="text-gray-500 text-sm max-w-md mb-10 leading-relaxed">
      Kein Baukastensystem. Wir implementieren ein vollständig integriertes System, das digitale Werbung mit echten Termindaten aus Ihrer Praxissoftware verbindet.
    </p>

    <div class="grid grid-cols-2 gap-3.5">
      {[
        {
          icon: `<rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18M9 21V9"/>`,
          title: 'Design & Inhalte',
          text: 'Professionelle Website mit Texten und Bildern, die Patienten überzeugen',
        },
        {
          icon: `<rect x="2" y="3" width="20" height="7" rx="1"/><rect x="2" y="14" width="20" height="7" rx="1"/><line x1="6" y1="6.5" x2="6.01" y2="6.5"/><line x1="6" y1="17.5" x2="6.01" y2="17.5"/>`,
          title: 'Betrieb der Website',
          text: 'Zuverlässiges Hosting, Updates und technischer Betrieb',
        },
        {
          icon: `<polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/>`,
          title: 'Kliniksoftware-Anbindung',
          text: 'Direkte Integration mit mobi.MED, Claysen und weiteren Praxis-CRM-Systemen',
        },
        {
          icon: `<path d="M3 11l19-9-9 19-2-8-8-2z"/>`,
          title: 'Google Ads & Meta',
          text: 'Gezielte Werbung für Ihre Behandlungen auf allen Kanälen',
        },
        {
          icon: `<polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/>`,
          title: 'Auswertung & Zahlen',
          text: 'Klares Reporting: welche Maßnahme welchen Patienten brachte',
        },
        {
          icon: `<path d="M3 18v-6a9 9 0 0 1 18 0v6"/><path d="M21 19a2 2 0 0 1-2 2h-1a2 2 0 0 1-2-2v-3a2 2 0 0 1 2-2h3zM3 19a2 2 0 0 0 2 2h1a2 2 0 0 0 2-2v-3a2 2 0 0 0-2-2H3z"/>`,
          title: 'Laufende Betreuung',
          text: 'Persönlicher Ansprechpartner für neue Ideen und Weiterentwicklung',
        },
      ].map((s) => (
        <div class="bg-gray-50 border border-gray-200 rounded-xl p-5 hover:border-blue hover:shadow-blue/10 hover:shadow-md transition-all">
          <div class="w-10 h-10 bg-blue rounded-xl flex items-center justify-center mb-3.5">
            <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" set:html={s.icon}/>
          </div>
          <h3 class="text-dark font-bold text-sm mb-1.5 leading-snug">{s.title}</h3>
          <p class="text-gray-500 text-xs leading-relaxed">{s.text}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- ── FOR WHOM ───────────────────────────────── -->
  <section class="bg-dark px-6 py-14 text-center">
    <p class="text-blue text-xs font-bold tracking-widest uppercase mb-3">Für wen</p>
    <h2 class="text-white font-extrabold text-2xl sm:text-3xl tracking-tight mb-8">
      Unsere Kunden
    </h2>
    <div class="flex flex-wrap gap-2.5 justify-center max-w-sm mx-auto">
      {[
        { label: 'Ästhetische Chirurgen', highlight: true },
        { label: 'Plastische Chirurgen', highlight: true },
        { label: 'Dermatologen (ästhetisch)', highlight: true },
        { label: 'Zahnärzte (Implantate · Aligner)', highlight: true },
        { label: 'Privatärztliche Kliniken', highlight: false },
        { label: 'Praxen mit eigenem Marketing', highlight: false },
      ].map((c) => (
        <span
          class={`text-xs font-medium px-4 py-2 rounded-full border ${
            c.highlight
              ? 'bg-blue/20 border-blue text-white font-semibold'
              : 'bg-white/8 border-white/15 text-white/80'
          }`}
        >
          {c.label}
        </span>
      ))}
    </div>
  </section>

  <!-- ── PROCESS ────────────────────────────────── -->
  <section class="px-6 py-16 max-w-xl mx-auto">
    <p class="text-blue text-xs font-bold tracking-widest uppercase mb-3">Zusammenarbeit</p>
    <h2 class="text-dark font-extrabold text-2xl sm:text-3xl tracking-tight mb-10">
      So arbeiten wir
    </h2>
    <div class="relative flex flex-col gap-0">
      <!-- vertical line -->
      <div class="absolute left-5 top-10 bottom-10 w-0.5 bg-gray-200"></div>

      {[
        { num: '1', title: 'Erstes Gespräch', text: 'Wir schauen gemeinsam, wo Sie stehen und was Sie brauchen. Kein Pitch, kein Druck.' },
        { num: '2', title: 'Konzept & Angebot', text: 'Wir erstellen ein klares Konzept mit konkreten Maßnahmen und transparenten Kosten.' },
        { num: '3', title: 'Umsetzung', text: 'Wir bauen, schalten, messen – und halten Sie laufend auf dem Laufenden.' },
        { num: '4', title: 'Laufende Partnerschaft', text: 'Ein Ansprechpartner, der Ihre Praxis kennt und langfristig mitdenkt.' },
      ].map((s, i) => (
        <div class={`flex gap-5 items-start relative ${i < 3 ? 'pb-8' : ''}`}>
          <div class="flex-shrink-0 w-10 h-10 rounded-full border-2 border-blue bg-white flex items-center justify-center text-blue font-extrabold text-sm z-10">
            {s.num}
          </div>
          <div class="pt-2">
            <h3 class="text-dark font-bold text-sm mb-1">{s.title}</h3>
            <p class="text-gray-500 text-xs leading-relaxed">{s.text}</p>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- ── REFERENCES ───────────────────────────── -->
  <section class="bg-dark px-6 py-16">
    <div class="max-w-2xl mx-auto">
      <p class="text-blue text-xs font-bold tracking-widest uppercase mb-3 text-center">Referenzen</p>
      <h2 class="text-white font-extrabold text-2xl sm:text-3xl tracking-tight mb-10 text-center">
        Kliniken, die uns vertrauen
      </h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">

        <!-- Praxisklinik Rosengarten -->
        <div class="bg-white/5 border border-white/10 rounded-2xl p-6 hover:border-blue/40 transition-colors">
          <div class="flex items-center gap-3 mb-4">
            <div class="w-10 h-10 rounded-xl bg-blue/20 flex items-center justify-center flex-shrink-0">
              <svg class="w-5 h-5 text-blue" viewBox="0 0 24 24" fill="none" stroke="#009fe3" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
            </div>
            <div>
              <h3 class="text-white font-bold text-sm">Praxisklinik Rosengarten</h3>
              <p class="text-white/40 text-xs">Ästhetische &amp; Plastische Chirurgie</p>
            </div>
          </div>
          <div class="space-y-2 mb-4">
            <div class="flex justify-between text-xs">
              <span class="text-white/50">Google Ads ROAS</span>
              <span class="text-white font-semibold">Ø 64x</span>
            </div>
            <div class="flex justify-between text-xs">
              <span class="text-white/50">Kosten pro Termin</span>
              <span class="text-white font-semibold">€ 22</span>
            </div>
            <div class="flex justify-between text-xs">
              <span class="text-white/50">CRM-Integration</span>
              <span class="text-white font-semibold">mobi.MED</span>
            </div>
          </div>
          <p class="text-white/40 text-xs leading-relaxed italic">
            „Seit der Zusammenarbeit mit Kicktemp haben wir volle Transparenz über unsere Marketingmaßnahmen."
          </p>
        </div>

        <!-- s-thetic -->
        <div class="bg-white/5 border border-white/10 rounded-2xl p-6 hover:border-blue/40 transition-colors">
          <div class="flex items-center gap-3 mb-4">
            <div class="w-10 h-10 rounded-xl bg-blue/20 flex items-center justify-center flex-shrink-0">
              <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="#009fe3" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
            </div>
            <div>
              <h3 class="text-white font-bold text-sm">s-thetic Klinik</h3>
              <p class="text-white/40 text-xs">Ästhetische Chirurgie · Mehrere Standorte</p>
            </div>
          </div>
          <div class="space-y-2 mb-4">
            <div class="flex justify-between text-xs">
              <span class="text-white/50">Leistungen</span>
              <span class="text-white font-semibold">Website · Ads · Technik</span>
            </div>
            <div class="flex justify-between text-xs">
              <span class="text-white/50">CRM-Integration</span>
              <span class="text-white font-semibold">Claysen</span>
            </div>
            <div class="flex justify-between text-xs">
              <span class="text-white/50">Standorte</span>
              <span class="text-white font-semibold">DACH-Region</span>
            </div>
          </div>
          <p class="text-white/40 text-xs leading-relaxed italic">
            „Kicktemp versteht die besonderen Anforderungen ästhetischer Kliniken wie kein anderer Dienstleister."
          </p>
        </div>

      </div>
    </div>
  </section>

  <!-- ── TEAM ──────────────────────────────────── -->
  <section class="px-6 py-16 max-w-2xl mx-auto">
    <p class="text-blue text-xs font-bold tracking-widest uppercase mb-3 text-center">Das Team</p>
    <h2 class="text-dark font-extrabold text-2xl sm:text-3xl tracking-tight mb-3 text-center">
      Menschen, nicht Maschinen
    </h2>
    <p class="text-gray-500 text-sm text-center max-w-sm mx-auto mb-10">
      Bei Kicktemp arbeiten Sie immer mit denselben Personen — kein Callcenter, kein ständiger Wechsel.
    </p>

    <div class="grid grid-cols-3 gap-6 mb-10">
      {[
        { name: 'Jenny Nübel', role: 'Gesellschafterin · Vertrieb & Kundenbetreuung', img: '/team/jenny.jpg' },
        { name: 'Niels Nübel', role: 'Geschäftsführer · Strategie & Technik', img: '/team/niels.jpg' },
        { name: 'Stefan Wendhausen', role: 'Geschäftsführer · Hosting & Infrastruktur', img: '/team/stefan.jpg' },
      ].map((p) => (
        <div class="text-center">
          <div class="w-full aspect-square rounded-2xl overflow-hidden bg-gray-100 mb-4 shadow-md">
            <img
              src={p.img}
              alt={p.name}
              title={p.name}
              width="600"
              height="600"
              class="w-full h-full object-cover object-top"
              loading="lazy"
            />
          </div>
          <h3 class="text-dark font-bold text-sm leading-snug">{p.name}</h3>
          <p class="text-gray-400 text-xs mt-1 leading-snug">{p.role}</p>
        </div>
      ))}
    </div>

  </section>

  <!-- ── CTA ───────────────────────────────────── -->
  <section class="bg-blue px-6 py-16 text-center" id="kontakt">
    <h2 class="text-white font-black text-3xl sm:text-4xl leading-tight tracking-tight mb-4">
      Bereit für mehr<br />Patienten?
    </h2>
    <p class="text-white/80 text-base leading-relaxed max-w-xs mx-auto mb-9">
      Sprechen Sie mit uns. Kein Verkaufsgespräch — wir schauen ehrlich,
      ob und wie wir helfen können.
    </p>
    <div class="flex flex-col items-center gap-3 w-full max-w-sm mx-auto">

      <!-- Termin buchen (Google Calendar) — primary CTA -->
      <a
        href="https://calendar.google.com/calendar/appointments/XXXXXXXXXXXXXXXX"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center justify-center gap-2.5 bg-white text-dark font-bold text-sm px-7 py-3.5 rounded-lg w-full hover:-translate-y-0.5 transition-transform"
        onclick="gtag && gtag('event', 'click_calendar', { event_category: 'cta' })"
      >
        <!-- Calendar icon -->
        <svg class="w-5 h-5 flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
        Termin buchen
      </a>

      <!-- Telefon (Sipgate) -->
      <a
        href="tel:+4940XXXXXXXX"
        class="inline-flex items-center justify-center gap-2.5 bg-white/20 border border-white/30 text-white font-bold text-sm px-7 py-3.5 rounded-lg w-full hover:bg-white/30 transition-colors"
        onclick="gtag && gtag('event', 'click_phone', { event_category: 'cta' })"
      >
        <svg class="w-5 h-5 flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 1.21h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.91a16 16 0 0 0 6.29 6.29l1.46-1.46a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
        +49 40 XX XXXXXXXX <!-- BITTE ERGÄNZEN -->
      </a>

      <!-- WhatsApp -->
      <a
        href="https://wa.me/49XXXXXXXXXX"
        class="inline-flex items-center justify-center gap-2.5 bg-white/20 border border-white/30 text-white font-bold text-sm px-7 py-3.5 rounded-lg w-full hover:bg-white/30 transition-colors"
        onclick="gtag && gtag('event', 'click_whatsapp', { event_category: 'cta' })"
      >
