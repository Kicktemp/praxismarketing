---
import BaseLayout from '../layouts/BaseLayout.astro';
import SiteNav from '../components/SiteNav.astro';
import SiteFooter from '../components/SiteFooter.astro';
---

<BaseLayout
  title="Praxis Performance System — Strategische Partner"
  description="Das Kicktemp Praxis Performance System als Umsatz-Multiplikator für Pharmaunternehmen und Medizintechnik: Messbar mehr Materialabsatz durch datengetriebenes Praxismarketing."
  path="/partner"
  robots="noindex, nofollow"
>
  <SiteNav />

  <!-- ── HERO ──────────────────────────────────── -->
  <section class="bg-dark px-6 py-20 text-center">
    <span class="inline-block bg-white/10 text-white/70 text-xs font-bold tracking-widest uppercase px-4 py-1.5 rounded-full mb-7 border border-white/20">
      Exklusiv · Limitiertes Pilotprogramm
    </span>
    <h1 class="text-white font-black text-4xl sm:text-5xl leading-tight tracking-tight mb-5 max-w-2xl mx-auto">
      Der Umsatz-Multiplikator<br />
      <span class="text-blue">für Ihren Außendienst.</span>
    </h1>
    <p class="text-white/65 text-base leading-relaxed max-w-xl mx-auto mb-10">
      Das <strong class="text-white/90">Kicktemp Praxis Performance System</strong> schließt die Datenlücke zwischen digitalem Marketing und der Praxissoftware Ihrer Ärzte — für messbar mehr Materialabsatz bei Ihren Top-Kliniken.
    </p>
    <a
      href="#pilot"
      class="inline-flex items-center gap-2.5 bg-blue text-white font-bold text-sm py-3.5 rounded-lg hover:bg-blue-dark transition-colors" style="padding-left: 2.5rem; padding-right: 2.5rem;"
    >
      Strategisches Erstgespräch anfragen
      <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
    </a>
  </section>

  <!-- ── PROBLEM ───────────────────────────────── -->
  <section class="px-6 py-16 max-w-2xl mx-auto">
    <p class="text-blue text-xs font-bold tracking-widest uppercase mb-3">Das Problem</p>
    <h2 class="text-dark font-extrabold text-2xl sm:text-3xl tracking-tight mb-5">
      Warum Praxis-Marketing heute im Blindflug stattfindet
    </h2>
    <p class="text-gray-600 text-sm leading-relaxed mb-8">
      Ärzte investieren in Google Ads — aber niemand weiß, welche Anzeige zu welchem gebuchten Termin geführt hat. Das Ergebnis: Budgets werden nach Bauchgefühl verteilt, und der Materialverbrauch Ihrer Praxen bleibt weit unter seinem Potenzial.
    </p>

    <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
      {[
        {
          icon: `<path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/>`,
          label: 'Keine Verbindung zwischen Klick und Termin',
        },
        {
          icon: `<circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/>`,
          label: 'Budgetverschwendung durch ungezielte Kampagnen',
        },
        {
          icon: `<polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/>`,
          label: 'Kein Feedback-Loop zwischen Behandlung und Werbealgorithmus',
        },
      ].map((i) => (
        <div class="bg-red-50 border border-red-100 rounded-xl p-5 text-center">
          <div class="w-10 h-10 bg-red-100 rounded-xl flex items-center justify-center mx-auto mb-3">
            <svg class="w-5 h-5 text-red-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" set:html={i.icon}/>
          </div>
          <p class="text-gray-700 text-xs leading-relaxed font-medium">{i.label}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- ── SOLUTION ──────────────────────────────── -->
  <section class="bg-dark px-6 py-16">
    <div class="max-w-2xl mx-auto">
      <p class="text-blue text-xs font-bold tracking-widest uppercase mb-3 text-center">Die Lösung</p>
      <h2 class="text-white font-extrabold text-2xl sm:text-3xl tracking-tight mb-4 text-center">
        Das B2B2C-Prinzip des<br />Praxis Performance Systems
      </h2>
      <p class="text-white/55 text-sm text-center max-w-lg mx-auto mb-12 leading-relaxed">
        Wir verbinden Ihren Außendienst, die Praxis Ihrer Ärzte und den Google-Werbealgorithmus zu einem geschlossenen Kreislauf — datenschutzkonform, vollautomatisch, messbar.
      </p>

      <div class="flex flex-col gap-6">
        {[
          {
            num: '1',
            title: 'Integration in die Praxissoftware',
            text: 'Wir binden mobi.MED oder Claysen direkt an. Jeder gebuchte Termin — ob Filler, Implantat oder Aligner — wird als Conversion erfasst. Nicht der Klick, der echte Termin.',
            highlight: false,
          },
          {
            num: '2',
            title: 'Algorithmus-Training mit echten Behandlungsdaten',
            text: 'Google Ads lernt, wer tatsächlich kauft. Der Algorithmus optimiert nicht mehr auf Klicks, sondern auf gebuchte High-Ticket-Behandlungen. Kosten sinken, Qualität steigt.',
            highlight: false,
          },
          {
            num: '3',
            title: 'Automatisch mehr Materialabsatz für Ihren Außendienst',
            text: 'Mehr gebuchte Behandlungen = mehr Materialverbrauch in der Praxis. Ihr Außendienst muss nicht mehr pushen — die Nachfrage entsteht digital, bevor der Vertreter die Praxis betritt.',
            highlight: true,
          },
        ].map((s) => (
          <div class={`flex gap-5 items-start rounded-2xl p-6 border ${s.highlight ? 'border-blue/40 bg-blue/8' : 'border-white/10 bg-white/4'}`}>
            <div class={`flex-shrink-0 w-10 h-10 rounded-full flex items-center justify-center font-extrabold text-sm ${s.highlight ? 'bg-blue text-white' : 'bg-white/15 text-white'}`}>
              {s.num}
            </div>
            <div>
              <h3 class={`font-bold text-sm mb-1.5 ${s.highlight ? 'text-blue' : 'text-white'}`}>{s.title}</h3>
              <p class="text-white/55 text-xs leading-relaxed">{s.text}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ── PROOF ─────────────────────────────────── -->
  <section class="px-6 py-16 max-w-2xl mx-auto">
    <p class="text-blue text-xs font-bold tracking-widest uppercase mb-3 text-center">Beweis</p>
    <h2 class="text-dark font-extrabold text-2xl sm:text-3xl tracking-tight mb-4 text-center">
      Zahlen aus der Praxis
    </h2>
    <p class="text-gray-500 text-sm text-center max-w-md mx-auto mb-10 leading-relaxed">
      Praxisklinik Rosengarten, ästhetische &amp; plastische Chirurgie — nach Implementierung des Praxis Performance Systems:
    </p>

    <div class="grid grid-cols-2 sm:grid-cols-4 gap-4 mb-10">
      {[
        { value: 'Ø 64x', label: 'ROAS Google Ads' },
        { value: '€ 22', label: 'Kosten pro Termin' },
        { value: '< 30', label: 'Tage bis Live-Betrieb' },
        { value: '100%', label: 'datengestützte Entscheidungen' },
      ].map((s) => (
        <div class="bg-dark text-center rounded-2xl p-5">
          <div class="text-white font-black text-2xl leading-none mb-1">{s.value}</div>
          <div class="text-white/40 text-xs leading-snug">{s.label}</div>
        </div>
      ))}
    </div>

    <div class="bg-gray-50 border border-gray-200 rounded-2xl p-6">
      <div class="flex items-start gap-4">
        <div class="w-10 h-10 rounded-xl bg-blue/15 flex items-center justify-center flex-shrink-0 mt-0.5">
          <svg class="w-5 h-5 text-blue" viewBox="0 0 24 24" fill="none" stroke="#009fe3" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
        </div>
        <div>
          <p class="text-dark font-semibold text-sm mb-1">Praxisklinik Rosengarten</p>
          <p class="text-gray-500 text-xs mb-3">Ästhetische &amp; Plastische Chirurgie · mobi.MED-Integration</p>
          <p class="text-gray-600 text-sm leading-relaxed italic">
            „Seit der Zusammenarbeit mit Kicktemp haben wir volle Transparenz über unsere Marketingmaßnahmen — und wissen erstmals genau, welche Kampagne welchen Patienten gebracht hat."
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ── FOR PHARMA ────────────────────────────── -->
  <section class="bg-dark px-6 py-16">
    <div class="max-w-2xl mx-auto">
      <p class="text-blue text-xs font-bold tracking-widest uppercase mb-3 text-center">Ihr Vorteil</p>
      <h2 class="text-white font-extrabold text-2xl sm:text-3xl tracking-tight mb-10 text-center">
        Was das System für Ihr Unternehmen bedeutet
      </h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        {[
          {
            title: 'Mehr Materialabsatz ohne Mehraufwand',
            text: 'Wenn wir die Nachfrage nach Fillern, Implantaten und Premium-Behandlungen in den Praxen Ihres Außendienstes steigern, kaufen diese Ärzte automatisch mehr bei Ihnen ein.',
          },
          {
            title: 'Ihr Außendienst als digitaler Türöffner',
            text: 'Ihre Vertreter bringen nicht nur Produkte — sie bringen ein schlüsselfertiges System, das die Praxis des Arztes profitabler macht. Ein unschlagbares Gesprächsthema.',
          },
          {
            title: 'Messbare ROI-Zahlen für Ihre Investition',
            text: 'Kein Marketing-Blindflug. Jeder gebuchte Termin, jede Behandlung ist trackt. Sie sehen auf Knopfdruck, wie viel Mehrumsatz das System pro Praxis erzeugt.',
          },
          {
            title: 'Exklusiv für Ihre Top-Praxen',
            text: 'Das Pilotprojekt ist auf 5 ausgewählte Kliniken limitiert. So stellen wir Qualität sicher — und Sie sichern sich einen klaren Wettbewerbsvorteil gegenüber anderen Herstellern.',
          },
        ].map((s) => (
          <div class="bg-white/5 border border-white/10 rounded-2xl p-6 hover:border-blue/30 transition-colors">
            <h3 class="text-white font-bold text-sm mb-2">{s.title}</h3>
            <p class="text-white/50 text-xs leading-relaxed">{s.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ── INDICATIONS ───────────────────────────── -->
  <section class="px-6 py-16 max-w-2xl mx-auto text-center">
    <p class="text-blue text-xs font-bold tracking-widest uppercase mb-3">Behandlungen</p>
    <h2 class="text-dark font-extrabold text-2xl sm:text-3xl tracking-tight mb-4">
      Kompatibel mit Ihrem gesamten High-Ticket-Portfolio
    </h2>
    <p class="text-gray-500 text-sm max-w-md mx-auto mb-8 leading-relaxed">
      Das System steigert die Nachfrage nach genau den Behandlungen, die für Ihr Haus relevant sind.
    </p>
    <div class="flex flex-wrap gap-2.5 justify-center">
      {[
        'Premium-Filler', 'Botulinumtoxin', 'Hyaluron', 'Dentalimplantate',
        'Aligner / Invisalign', 'Fadenlifting', 'Laser-Behandlungen',
        'Körperformung', 'Brust-OP', 'Nasen-OP',
      ].map((t) => (
        <span class="text-xs font-medium px-4 py-2 rounded-full border bg-blue/8 border-blue/30 text-dark">
          {t}
        </span>
      ))}
    </div>
  </section>

  <!-- ── CTA ───────────────────────────────────── -->
  <section class="bg-dark px-6 text-center" id="pilot" style="padding-top: 7rem; padding-bottom: 7rem;">
    <p class="text-blue text-xs font-bold tracking-widest uppercase mb-5">Pilotprojekt</p>
    <h2 class="text-white font-black text-3xl sm:text-4xl leading-tight tracking-tight mb-5 max-w-xl mx-auto">
      Gemeinsam wachsen:<br />
      <span class="text-blue">5 Kliniken. 30 Tage. Schlüsselfertig.</span>
    </h2>
    <p class="text-white/60 text-sm leading-relaxed max-w-lg mx-auto mb-4">
      Starten Sie ein exklusives Pilotprojekt mit 5 ausgewählten Top-Kliniken Ihres Vertrauens. Wir liefern das vollständig integrierte Praxis Performance System — von der Einrichtung bis zu den ersten messbaren Terminen — in 30 Tagen. Kein Risiko, klare Zahlen.
    </p>

    <div class="max-w-sm mx-auto flex flex-col gap-3">
      <a
        href="mailto:praxismarketing@kicktemp.com?subject=Pilotprojekt%20Pharma%20Partner"
        class="inline-flex items-center justify-center gap-3 bg-blue text-white font-bold text-base px-10 py-5 rounded-xl w-full hover:bg-blue-dark transition-colors whitespace-nowrap"
      >
        <svg class="w-5 h-5 flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
        Strategisches Erstgespräch anfragen
      </a>
      <a
        href="tel:+4940XXXXXXXX"
        class="inline-flex items-center justify-center gap-2.5 bg-white/10 border border-white/20 text-white font-semibold text-sm px-7 py-3.5 rounded-lg w-full hover:bg-white/15 transition-colors"
      >
        <svg class="w-5 h-5 flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 1.21h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.91a16 16 0 0 0 6.29 6.29l1.46-1.46a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
        Direkt anrufen
      </a>
    </div>
  </section>

  <SiteFooter />
</BaseLayout>
